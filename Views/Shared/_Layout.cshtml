<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InnebandyStats</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/InnebandyStats.styles.css" asp-append-version="true" />
    <style>
        .fav-btn { background: none; border: none; padding: 2px 6px; font-size: 1.3rem; line-height: 1; color: #999; cursor: pointer; vertical-align: middle; transition: color .15s; }
        .fav-btn.active { color: #f5a623; }
        .fav-btn:hover { color: #f5a623; transform: scale(1.15); }
        .fav-inline { background: none; border: none; padding: 0 3px; font-size: 1rem; line-height: 1; color: #bbb; cursor: pointer; vertical-align: middle; transition: color .15s; }
        .fav-inline.active { color: #f5a623; }
        .fav-inline:hover { color: #f5a623; }
        #favQuickLinks a { transition: background .15s; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-dark bg-dark border-bottom box-shadow">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">InnebandyStats</a>
                <div class="dropdown">
                    <button class="btn btn-outline-light btn-sm dropdown-toggle" type="button" id="favDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                        ★ Favoriter &amp; Samlingar
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end" id="favMenu" style="min-width:260px; max-height:400px; overflow-y:auto;">
                        <li><span class="dropdown-item-text text-muted small" id="favEmpty">Inga favoriter sparade</span></li>
                    </ul>
                </div>
            </div>
        </nav>
        <div class="bg-light border-bottom py-2" id="pickerBar">
            <div class="container-fluid">
                <div class="row g-2 align-items-end">
                    <div class="col-md-2">
                        <label for="seasonSelect" class="form-label small mb-0">Säsong</label>
                        <select class="form-select form-select-sm" id="seasonSelect"></select>
                    </div>
                    <div class="col-md-3">
                        <label for="federationSelect" class="form-label small mb-0">Förbund</label>
                        <select class="form-select form-select-sm" id="federationSelect"></select>
                    </div>
                    <div class="col-md-5">
                        <label for="seriesSearch" class="form-label small mb-0">Serie</label>
                        <div class="position-relative">
                            <input type="text" class="form-control form-control-sm" id="seriesSearch"
                                   placeholder="Sök serie..." autocomplete="off" />
                            <ul id="seriesList"
                                style="display:none; position:absolute; z-index:1050; width:100%; max-height:260px; overflow-y:auto; margin:2px 0 0; padding:0; list-style:none; background:#fff; border:1px solid #ced4da; border-radius:4px; box-shadow:0 4px 12px rgba(0,0,0,.15);"></ul>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-primary btn-sm w-100" id="goBtn" disabled>Hämta</button>
                    </div>
                </div>
                <div class="row mt-2" id="favQuickLinks" style="display:none;">
                    <div class="col-12 d-flex flex-wrap align-items-center gap-2">
                        <span class="small text-muted">★ Favoriter:</span>
                        <span id="favQuickLinksContainer"></span>
                    </div>
                </div>
            </div>
        </div>
    </header>
    <div class="container-fluid">
        <main role="main" class="pb-3 mt-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container d-flex justify-content-between">
            <span>&copy; 2026 - InnebandyStats</span>
            <span class="small">
                Deploy:
                @{
                    var assembly = System.Reflection.Assembly.GetExecutingAssembly();
                    var buildDate = System.IO.File.GetLastWriteTime(assembly.Location);
                }
                @buildDate.ToString("yyyy-MM-dd HH:mm")
            </span>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // ── Collections helpers ────────────────────────────────────────────────
        const COLLECTIONS_KEY = 'innebandystats_collections';

        function getCollections() {
            try { return JSON.parse(localStorage.getItem(COLLECTIONS_KEY) || '[]'); } catch { return []; }
        }
        function saveCollections(arr) { localStorage.setItem(COLLECTIONS_KEY, JSON.stringify(arr)); }

        function createCollection(name) {
            var cols = getCollections();
            var col = { id: Date.now().toString(), name: name, teams: [] };
            cols.push(col);
            saveCollections(cols);
            return col;
        }
        function addTeamToCollection(colId, teamName, competitionId, competitionName) {
            var cols = getCollections();
            var col = cols.find(c => c.id === colId);
            if (!col) return;
            if (!col.teams.some(t => t.name === teamName && t.competitionId == competitionId))
                col.teams.push({ name: teamName, competitionId: String(competitionId), competitionName: competitionName });
            saveCollections(cols);
        }
        function removeTeamFromCollection(colId, teamName, competitionId) {
            var cols = getCollections();
            var col = cols.find(c => c.id === colId);
            if (!col) return;
            col.teams = col.teams.filter(t => !(t.name === teamName && t.competitionId == competitionId));
            saveCollections(cols);
        }
        function deleteCollection(colId) {
            saveCollections(getCollections().filter(c => c.id !== colId));
            renderFavMenu();
        }

        // ── Favorites helpers ──────────────────────────────────────────────────
        const FAV_SERIES_KEY  = 'innebandystats_fav_series';
        const FAV_TEAMS_KEY   = 'innebandystats_fav_teams';
        const FAV_PLAYERS_KEY = 'innebandystats_fav_players';

        function getFavs(key) {
            try { return JSON.parse(localStorage.getItem(key) || '[]'); } catch { return []; }
        }
        function setFavs(key, arr) { localStorage.setItem(key, JSON.stringify(arr)); }

        function isFavSeries(id)  { return getFavs(FAV_SERIES_KEY).some(x => x.id == id); }
        function isFavTeam(name, competitionId) { return getFavs(FAV_TEAMS_KEY).some(x => x.name === name && x.competitionId == competitionId); }
        function isFavPlayer(id) { return getFavs(FAV_PLAYERS_KEY).some(x => x.id == id); }

        function toggleFavSeries(id, name) {
            var favs = getFavs(FAV_SERIES_KEY);
            var idx = favs.findIndex(x => x.id == id);
            if (idx >= 0) favs.splice(idx, 1); else favs.push({ id: String(id), name });
            setFavs(FAV_SERIES_KEY, favs);
            renderFavMenu();
            return idx < 0; // true = added
        }
        function toggleFavTeam(teamName, competitionId, competitionName) {
            var favs = getFavs(FAV_TEAMS_KEY);
            var idx = favs.findIndex(x => x.name === teamName && x.competitionId == competitionId);
            if (idx >= 0) favs.splice(idx, 1); else favs.push({ name: teamName, competitionId: String(competitionId), competitionName });
            setFavs(FAV_TEAMS_KEY, favs);
            renderFavMenu();
            return idx < 0;
        }
        function toggleFavPlayer(id, name) {
            var favs = getFavs(FAV_PLAYERS_KEY);
            var idx = favs.findIndex(x => x.id == id);
            if (idx >= 0) favs.splice(idx, 1); else favs.push({ id: String(id), name });
            setFavs(FAV_PLAYERS_KEY, favs);
            renderFavMenu();
            return idx < 0;
        }

        function renderFavMenu() {
            var menu = document.getElementById('favMenu');
            var emptyMsg = document.getElementById('favEmpty');
            var series  = getFavs(FAV_SERIES_KEY);
            var teams   = getFavs(FAV_TEAMS_KEY);
            var players = getFavs(FAV_PLAYERS_KEY);

            // Remove all items except the empty message placeholder
            Array.from(menu.querySelectorAll('li:not(:first-child)')).forEach(el => el.remove());

            var hasAny = series.length > 0 || teams.length > 0 || players.length > 0;
            emptyMsg.style.display = hasAny ? 'none' : '';
            renderFavQuickLinks();

            if (series.length > 0) {
                var hdr = document.createElement('li');
                hdr.innerHTML = '<span class="dropdown-item-text fw-semibold small text-uppercase text-muted">Serier</span>';
                menu.appendChild(hdr);
                series.forEach(function(s) {
                    var li = document.createElement('li');
                    li.innerHTML = '<span class="d-flex align-items-center">'
                        + '<a class="dropdown-item flex-grow-1" href="/Home/Standings?id=' + encodeURIComponent(s.id) + '">' + escHtml(s.name) + '</a>'
                        + '<button class="btn btn-sm fav-inline active me-2" title="Ta bort favorit" onclick="removeFavSeries(\'' + s.id + '\', this)">★</button>'
                        + '</span>';
                    menu.appendChild(li);
                });
            }

            if (teams.length > 0) {
                var hdr2 = document.createElement('li');
                hdr2.innerHTML = '<li><hr class="dropdown-divider"></li><span class="dropdown-item-text fw-semibold small text-uppercase text-muted">Lag</span>';
                menu.appendChild(hdr2);
                teams.forEach(function(t) {
                    var li = document.createElement('li');
                    li.innerHTML = '<span class="d-flex align-items-center">'
                        + '<a class="dropdown-item flex-grow-1" href="/Home/TeamView?competitionId=' + encodeURIComponent(t.competitionId) + '&teamName=' + encodeURIComponent(t.name) + '">' + escHtml(t.name) + ' <small class="text-muted">' + escHtml(t.competitionName || '') + '</small></a>'
                        + '<button class="btn btn-sm fav-inline active me-2" title="Ta bort favorit" onclick="removeFavTeam(\'' + escHtml(t.name) + '\', \'' + t.competitionId + '\', this)">★</button>'
                        + '</span>';
                    menu.appendChild(li);
                });
            }

            if (players.length > 0) {
                var hdr3 = document.createElement('li');
                hdr3.innerHTML = '<li><hr class="dropdown-divider"></li><span class="dropdown-item-text fw-semibold small text-uppercase text-muted">Spelare</span>';
                menu.appendChild(hdr3);
                players.forEach(function(p) {
                    var li = document.createElement('li');
                    li.innerHTML = '<span class="d-flex align-items-center">'
                        + '<a class="dropdown-item flex-grow-1" href="https://stats.innebandy.se/spelare/' + encodeURIComponent(p.id) + '" target="_blank">' + escHtml(p.name) + '</a>'
                        + '<button class="btn btn-sm fav-inline active me-2" title="Ta bort favorit" onclick="removeFavPlayer(\'' + p.id + '\', this)">★</button>'
                        + '</span>';
                    menu.appendChild(li);
                });
            }

            // Collections
            var collections = getCollections().filter(c => c.teams.length > 0);
            if (collections.length > 0) {
                var hdrC = document.createElement('li');
                hdrC.innerHTML = '<li><hr class="dropdown-divider"></li><span class="dropdown-item-text fw-semibold small text-uppercase text-muted">Samlingar</span>';
                menu.appendChild(hdrC);
                collections.forEach(function(col) {
                    var li = document.createElement('li');
                    var teamsHtml = col.teams.map(function(t) {
                        return '<a class="dropdown-item ps-4 py-1 small" href="/Home/TeamAnalysis?competitionId=' + encodeURIComponent(t.competitionId) + '&teamName=' + encodeURIComponent(t.name) + '">' + escHtml(t.name) + '</a>';
                    }).join('');
                    li.innerHTML = '<span class="dropdown-item-text fw-semibold d-flex align-items-center">'
                        + '<span class="flex-grow-1">📋 ' + escHtml(col.name) + '</span>'
                        + '<button class="btn btn-sm fav-inline me-2" title="Ta bort samling" onclick="deleteCollection(\'' + col.id + '\')">✕</button>'
                        + '</span>'
                        + teamsHtml;
                    menu.appendChild(li);
                });
            }
        }

        function removeFavSeries(id, btn) {
            var favs = getFavs(FAV_SERIES_KEY).filter(x => x.id != id);
            setFavs(FAV_SERIES_KEY, favs);
            renderFavMenu();
            // update star btn on page if present
            document.querySelectorAll('.fav-series-btn[data-id="' + id + '"]').forEach(function(b) {
                b.textContent = '☆'; b.classList.remove('active');
            });
        }
        function removeFavTeam(name, competitionId, btn) {
            var favs = getFavs(FAV_TEAMS_KEY).filter(x => !(x.name === name && x.competitionId == competitionId));
            setFavs(FAV_TEAMS_KEY, favs);
            renderFavMenu();
            document.querySelectorAll('.fav-team-btn[data-name="' + name + '"][data-competition-id="' + competitionId + '"]').forEach(function(b) {
                b.textContent = '☆'; b.classList.remove('active');
            });
        }
        function removeFavPlayer(id, btn) {
            var favs = getFavs(FAV_PLAYERS_KEY).filter(x => x.id != id);
            setFavs(FAV_PLAYERS_KEY, favs);
            renderFavMenu();
            document.querySelectorAll('.fav-player-btn[data-id="' + id + '"]').forEach(function(b) {
                b.textContent = '☆'; b.classList.remove('active');
            });
        }

        function renderFavQuickLinks() {
            var container = document.getElementById('favQuickLinksContainer');
            var wrapper = document.getElementById('favQuickLinks');
            if (!container || !wrapper) return;
            var series = getFavs(FAV_SERIES_KEY);
            var teams = getFavs(FAV_TEAMS_KEY);
            var collections = getCollections().filter(c => c.teams.length > 0);
            container.innerHTML = '';
            if (series.length === 0 && teams.length === 0 && collections.length === 0) {
                wrapper.style.display = 'none'; return;
            }
            wrapper.style.display = '';
            series.forEach(function(s) {
                var a = document.createElement('a');
                a.href = '/Home/Standings?id=' + encodeURIComponent(s.id);
                a.className = 'badge bg-primary text-decoration-none';
                a.textContent = s.name;
                container.appendChild(a);
            });
            teams.forEach(function(t) {
                var a = document.createElement('a');
                a.href = '/Home/TeamAnalysis?competitionId=' + encodeURIComponent(t.competitionId) + '&teamName=' + encodeURIComponent(t.name);
                a.className = 'badge bg-secondary text-decoration-none';
                a.textContent = t.name;
                container.appendChild(a);
            });
            collections.forEach(function(col) {
                var span = document.createElement('span');
                span.className = 'badge bg-dark text-decoration-none me-0';
                span.textContent = '📋 ' + col.name + ':';
                container.appendChild(span);
                col.teams.forEach(function(t) {
                    var a = document.createElement('a');
                    a.href = '/Home/TeamAnalysis?competitionId=' + encodeURIComponent(t.competitionId) + '&teamName=' + encodeURIComponent(t.name);
                    a.className = 'badge bg-secondary text-decoration-none';
                    a.textContent = t.name;
                    container.appendChild(a);
                });
            });
        }

        function escHtml(s) {
            return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        function initFavSeriesBtn(btn) {
            if (!btn) return;
            var id = btn.dataset.id, name = btn.dataset.name;
            if (isFavSeries(id)) { btn.textContent = '★'; btn.classList.add('active'); }
            btn.addEventListener('click', function() {
                var added = toggleFavSeries(id, name);
                btn.textContent = added ? '★' : '☆';
                btn.classList.toggle('active', added);
            });
        }
        function initFavTeamBtns(competitionId, competitionName) {
            document.querySelectorAll('.fav-team-btn').forEach(function(btn) {
                var name = btn.dataset.name;
                if (isFavTeam(name, competitionId)) { btn.textContent = '★'; btn.classList.add('active'); }
                btn.addEventListener('click', function() {
                    var added = toggleFavTeam(name, competitionId, competitionName);
                    btn.textContent = added ? '★' : '☆';
                    btn.classList.toggle('active', added);
                });
            });
        }
        function initFavPlayerBtns() {
            document.querySelectorAll('.fav-player-btn').forEach(function(btn) {
                var id = btn.dataset.id, name = btn.dataset.name;
                if (isFavPlayer(id)) { btn.textContent = '★'; btn.classList.add('active'); }
                btn.addEventListener('click', function() {
                    var added = toggleFavPlayer(id, name);
                    btn.textContent = added ? '★' : '☆';
                    btn.classList.toggle('active', added);
                });
            });
        }

        // ── Picker bar ─────────────────────────────────────────────────────────
        document.addEventListener('DOMContentLoaded', function () {
            renderFavMenu();

            const seasonSelect = document.getElementById('seasonSelect');
            const federationSelect = document.getElementById('federationSelect');
            const seriesSearch = document.getElementById('seriesSearch');
            const seriesList = document.getElementById('seriesList');
            const goBtn = document.getElementById('goBtn');

            let allCompetitions = [];
            let selectedCompetitionId = null;

            Promise.all([
                fetch('/Home/GetSeasons').then(r => r.json()),
                fetch('/Home/GetFederations').then(r => r.json())
            ]).then(([seasons, federations]) => {
                const savedSeason = localStorage.getItem('selectedSeasonId');
                const savedFederation = localStorage.getItem('selectedFederationId');

                seasons.forEach(s => {
                    const opt = document.createElement('option');
                    opt.value = s.seasonID;
                    opt.text = s.name;
                    if (savedSeason ? s.seasonID == savedSeason : s.isCurrentSeason) opt.selected = true;
                    seasonSelect.appendChild(opt);
                });

                federations.forEach(f => {
                    const opt = document.createElement('option');
                    opt.value = f.federationID;
                    opt.text = f.name;
                    if (savedFederation ? f.federationID == savedFederation : f.federationID == 8) opt.selected = true;
                    federationSelect.appendChild(opt);
                });

                loadCompetitions();
            });

            seasonSelect.addEventListener('change', function () {
                localStorage.setItem('selectedSeasonId', seasonSelect.value);
                loadCompetitions();
            });

            federationSelect.addEventListener('change', function () {
                localStorage.setItem('selectedFederationId', federationSelect.value);
                loadCompetitions();
            });

            async function loadCompetitions() {
                selectedCompetitionId = null;
                goBtn.disabled = true;
                seriesSearch.value = '';
                seriesList.style.display = 'none';
                seriesSearch.placeholder = 'Laddar serier...';

                try {
                    const res = await fetch(`/Home/GetCompetitions?seasonId=${seasonSelect.value}&federationId=${federationSelect.value}`);
                    const data = await res.json();
                    allCompetitions = data.map(c => ({ id: c.competitionID.toString(), name: c.name }));
                    seriesSearch.placeholder = `Sök bland ${allCompetitions.length} serier...`;
                } catch (e) {
                    seriesSearch.placeholder = 'Kunde inte ladda serier';
                    allCompetitions = [];
                }
            }

            seriesSearch.addEventListener('focus', () => filterAndShow(seriesSearch.value));
            seriesSearch.addEventListener('input', () => filterAndShow(seriesSearch.value));

            function filterAndShow(query) {
                const lower = query.toLowerCase();
                seriesList.innerHTML = '';

                const favSeries = getFavs(FAV_SERIES_KEY);
                let filtered = allCompetitions.filter(c => c.name.toLowerCase().includes(lower));

                filtered.forEach(c => {
                    const li = document.createElement('li');
                    const isFav = favSeries.some(f => f.id == c.id);
                    li.style.cssText = 'display:flex; align-items:center; padding:4px 8px;';

                    const nameSpan = document.createElement('span');
                    nameSpan.textContent = c.name;
                    nameSpan.style.cssText = 'flex:1; font-size:0.875rem; cursor:pointer; padding:4px;';
                    nameSpan.addEventListener('mouseenter', () => nameSpan.style.background = '#e9ecef');
                    nameSpan.addEventListener('mouseleave', () => nameSpan.style.background = '');
                    nameSpan.addEventListener('mousedown', (e) => { e.preventDefault(); selectSeries(c.id, c.name); });
                    nameSpan.addEventListener('touchend', (e) => { e.preventDefault(); selectSeries(c.id, c.name); });

                    const starBtn = document.createElement('button');
                    starBtn.textContent = isFav ? '★' : '☆';
                    starBtn.className = 'fav-inline' + (isFav ? ' active' : '');
                    starBtn.title = isFav ? 'Ta bort favorit' : 'Favoritmarkera';
                    starBtn.addEventListener('mousedown', function(e) {
                        e.preventDefault();
                        e.stopPropagation();
                        var added = toggleFavSeries(c.id, c.name);
                        starBtn.textContent = added ? '★' : '☆';
                        starBtn.classList.toggle('active', added);
                    });

                    li.appendChild(nameSpan);
                    li.appendChild(starBtn);
                    seriesList.appendChild(li);
                });

                seriesList.style.display = filtered.length > 0 ? 'block' : 'none';
            }

            function selectSeries(id, name) {
                selectedCompetitionId = id;
                seriesSearch.value = name;
                seriesList.style.display = 'none';
                goBtn.disabled = false;
            }

            document.addEventListener('click', function (e) {
                if (!seriesSearch.contains(e.target) && !seriesList.contains(e.target)) {
                    seriesList.style.display = 'none';
                }
            });

            goBtn.addEventListener('click', function () {
                if (selectedCompetitionId) {
                    window.location.href = `/Home/Standings?id=${selectedCompetitionId}`;
                }
            });

            seriesSearch.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    if (selectedCompetitionId) {
                        window.location.href = `/Home/Standings?id=${selectedCompetitionId}`;
                    }
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
