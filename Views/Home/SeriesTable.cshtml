@model InnebandyStats.Models.SeriesTableViewModel
@{
    ViewData["Title"] = Model.CompetitionName + " – Tabell";
}

<div class="container mt-4">
    <h1 class="mb-1">
        <a id="seriesLink" href="#" target="_blank" class="text-decoration-none">@Model.CompetitionName</a>
        <button class="btn btn-sm ms-2 fav-btn fav-series-btn"
                data-id="@Model.CompetitionId"
                data-name="@Model.CompetitionName"
                title="Favoritmarkera serien">☆</button>
    </h1>

    <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            <a class="nav-link" asp-action="Standings" asp-route-id="@Model.CompetitionId">Spelarlista</a>
        </li>
        <li class="nav-item">
            <a class="nav-link active" href="#">Serietabell</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-action="Matches" asp-route-id="@Model.CompetitionId">Matcher</a>
        </li>
    </ul>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (Model.Table.Count == 0 && string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-info">Inga spelade matcher hittades för denna serie.</div>
    }

    @if (Model.Table.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Lag</th>
                        <th class="text-center">M</th>
                        <th class="text-center">V</th>
                        <th class="text-center">O</th>
                        <th class="text-center">F</th>
                        <th class="text-center">GM</th>
                        <th class="text-center">IM</th>
                        <th class="text-center">+/-</th>
                        <th class="text-center">P</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var rank = 1; }
                    @foreach (var team in Model.Table)
                    {
                        <tr>
                            <td>@rank</td>
                            <td>
                                <a asp-action="TeamView"
                                   asp-route-competitionId="@Model.CompetitionId"
                                   asp-route-teamName="@team.TeamName"
                                   class="text-decoration-none text-dark fw-semibold">@team.TeamName</a>
                                <button class="fav-inline fav-team-btn"
                                        data-name="@team.TeamName"
                                        data-competition-id="@Model.CompetitionId"
                                        title="Favoritmarkera lag">☆</button>
                                <a asp-action="TeamAnalysis"
                                   asp-route-competitionId="@Model.CompetitionId"
                                   asp-route-teamName="@team.TeamName"
                                   class="text-muted small ms-1" title="Analysera lag">📊</a>
                            </td>
                            <td class="text-center">@team.Played</td>
                            <td class="text-center">@team.Wins</td>
                            <td class="text-center">@team.Draws</td>
                            <td class="text-center">@team.Losses</td>
                            <td class="text-center">@team.GoalsFor</td>
                            <td class="text-center">@team.GoalsAgainst</td>
                            <td class="text-center">@(team.GoalDiff > 0 ? "+" : "")@team.GoalDiff</td>
                            <td class="text-center"><strong>@team.Points</strong></td>
                        </tr>
                        rank++;
                    }
                </tbody>
            </table>
        </div>
        <p class="text-muted small">M=Matcher, V=Vinster, O=Oavgjorda, F=Förluster, GM=Gjorda mål, IM=Insläppta mål, +/-=Målskillnad, P=Poäng</p>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var seasonId = localStorage.getItem('selectedSeasonId') || '43';
            var link = document.getElementById('seriesLink');
            if (link) {
                link.href = 'https://stats.innebandy.se/sasong/' + seasonId + '/serie/@Model.CompetitionId/serietabell';
            }
            initFavSeriesBtn(document.querySelector('.fav-series-btn'));
            initFavTeamBtns('@Model.CompetitionId', @Json.Serialize(Model.CompetitionName));
        });
    </script>
}
