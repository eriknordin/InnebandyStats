@model InnebandyStats.Models.MatchViewModel
@{
    bool isPlayed = Model.GoalsHomeTeam.HasValue && Model.GoalsAwayTeam.HasValue;
    bool hasSeasonStats = Model.SeasonStats.Count > 0;
    ViewData["Title"] = isPlayed
        ? $"{Model.HomeTeam} {Model.GoalsHomeTeam}–{Model.GoalsAwayTeam} {Model.AwayTeam}"
        : $"{Model.HomeTeam} vs {Model.AwayTeam}";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb" class="mb-2">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-action="Matches" asp-route-id="@Model.CompetitionId">@Model.CompetitionName</a>
            </li>
            <li class="breadcrumb-item active">
                @if (isPlayed)
                {
                    @($"{Model.HomeTeam} {Model.GoalsHomeTeam}–{Model.GoalsAwayTeam} {Model.AwayTeam}")
                }
                else
                {
                    @($"{Model.HomeTeam} vs {Model.AwayTeam}")
                }
            </li>
        </ol>
    </nav>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }
    else
    {
        <div class="card mb-4">
            <div class="card-body text-center py-4">
                <div class="text-muted small mb-2">
                    @Model.MatchDateTime.ToString("dddd d MMMM yyyy HH:mm", new System.Globalization.CultureInfo("sv-SE"))
                    @if (!string.IsNullOrEmpty(Model.Venue))
                    {
                        <span> · @Model.Venue</span>
                    }
                    @if (!string.IsNullOrEmpty(Model.RoundName))
                    {
                        <span> · @Model.RoundName</span>
                    }
                </div>
                <div class="d-flex justify-content-center align-items-center gap-4">
                    <div class="text-end" style="width: 200px;">
                        <span class="fs-5 fw-bold">@Model.HomeTeam</span>
                    </div>
                    <div class="text-center px-3">
                        @if (isPlayed)
                        {
                            <span class="display-4 fw-bold">@Model.GoalsHomeTeam – @Model.GoalsAwayTeam</span>
                        }
                        else
                        {
                            <span class="display-4 text-muted">vs</span>
                        }
                    </div>
                    <div style="width: 200px;">
                        <span class="fs-5 fw-bold">@Model.AwayTeam</span>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.HomeTeamStandings.Count == 0 && Model.AwayTeamStandings.Count == 0)
        {
            <div class="alert alert-info">Ingen spelardata finns tillgänglig för denna match.</div>
        }
        else
        {
            @foreach (var teamData in new[] {
                new { Name = Model.HomeTeam, Players = Model.HomeTeamStandings },
                new { Name = Model.AwayTeam, Players = Model.AwayTeamStandings }
            })
            {
                <h5 class="mb-3 mt-4">@teamData.Name</h5>
                @if (teamData.Players.Count == 0)
                {
                    <p class="text-muted small">Inga spelardata.</p>
                }
                else
                {
                    <div class="table-responsive mb-4">
                        <table class="table table-sm table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>#</th>
                                    <th>Namn</th>
                                    <th>Födelseår</th>
                                    @if (isPlayed)
                                    {
                                        <th class="text-center">Mål</th>
                                        <th class="text-center">Assist</th>
                                        <th class="text-center">Poäng</th>
                                        <th class="text-center">Utv.min</th>
                                    }
                                    @if (hasSeasonStats)
                                    {
                                        <th class="text-center table-secondary">S:M</th>
                                        <th class="text-center table-secondary">S:Mål</th>
                                        <th class="text-center table-secondary">S:Assist</th>
                                        <th class="text-center table-secondary">S:Poäng</th>
                                        <th class="text-center table-secondary">S:P/M</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @{ var r = 1; }
                                @foreach (var p in teamData.Players)
                                {
                                    Model.SeasonStats.TryGetValue(p.PlayerID, out var season);
                                    <tr>
                                        <td>@r</td>
                                        <td><a href="https://stats.innebandy.se/spelare/@p.PlayerID" target="_blank" class="text-decoration-none text-dark fw-semibold">@p.Name</a></td>
                                        <td>@(p.BirthYear > 0 ? p.BirthYear.ToString() : (season?.BirthYear > 0 ? season.BirthYear.ToString() : ""))</td>
                                        @if (isPlayed)
                                        {
                                            <td class="text-center">@p.Goals</td>
                                            <td class="text-center">@p.Assists</td>
                                            <td class="text-center"><strong>@p.Points</strong></td>
                                            <td class="text-center">@(p.PenaltyMinutes > 0 ? p.PenaltyMinutes.ToString() : "-")</td>
                                        }
                                        @if (hasSeasonStats)
                                        {
                                            <td class="text-center table-light">@(season?.Matches.ToString() ?? "-")</td>
                                            <td class="text-center table-light">@(season?.Goals.ToString() ?? "-")</td>
                                            <td class="text-center table-light">@(season?.Assists.ToString() ?? "-")</td>
                                            <td class="text-center table-light"><strong>@(season?.Points.ToString() ?? "-")</strong></td>
                                            <td class="text-center table-light">@(season?.PointsPerGame.ToString("0.00") ?? "-")</td>
                                        }
                                    </tr>
                                    r++;
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }

            @if (hasSeasonStats)
            {
                <p class="text-muted small">S: = Säsongsstatistik. M=Matcher, P/M=Poäng per match</p>
            }
        }
    }
</div>
