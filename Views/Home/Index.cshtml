@model InnebandyStats.Models.CompetitionViewModel
@{
    ViewData["Title"] = "Poängliga";
}

<div class="container mt-4">
    <h1 class="mb-4">Innebandy Poängliga</h1>

    <form method="post" class="mb-4">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label for="seasonSelect" class="form-label">Välj säsong</label>
                <select class="form-select" id="seasonSelect" name="seasonId">
                    @foreach (var s in Model.AvailableSeasons)
                    {
                        <option value="@s.SeasonID" selected="@(s.SeasonID == Model.SelectedSeasonId)">@s.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label for="federationSelect" class="form-label">Välj förbund</label>
                <select class="form-select" id="federationSelect" name="federationId">
                    @foreach (var f in Model.AvailableFederations)
                    {
                        <option value="@f.FederationID" selected="@(f.FederationID == Model.SelectedFederationId)">@f.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label for="searchInput" class="form-label">Välj serie</label>
                <div class="position-relative">
                    <input type="text" class="form-control" id="searchInput"
                           placeholder="Sök serie..." autocomplete="off" />
                    <select class="form-select mt-1 position-absolute" id="competitionSelect" size="10"
                            style="display:none; z-index:1000;">
                        @foreach (var c in Model.AvailableCompetitions)
                        {
                            <option value="@c.CompetitionID"
                                    selected="@(Model.CompetitionId == c.CompetitionID)">@c.Name</option>
                        }
                    </select>
                </div>
                <input type="hidden" id="competitionId" name="competitionId"
                       value="@(Model.CompetitionId > 0 ? Model.CompetitionId.ToString() : "")" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Hämta</button>
            </div>
        </div>
    </form>

    @if (!string.IsNullOrEmpty(Model?.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @Model.ErrorMessage
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const seasonSelect = document.getElementById('seasonSelect');
            const federationSelect = document.getElementById('federationSelect');
            const searchInput = document.getElementById('searchInput');
            const competitionSelect = document.getElementById('competitionSelect');
            const hiddenInput = document.getElementById('competitionId');

            let allOptions = getOptionsFromSelect();

            function getOptionsFromSelect() {
                return Array.from(competitionSelect.options).map(opt => ({
                    value: opt.value,
                    text: opt.text
                }));
            }

            // Reload competitions when season or federation changes
            seasonSelect.addEventListener('change', loadCompetitions);
            federationSelect.addEventListener('change', loadCompetitions);

            async function loadCompetitions() {
                const seasonId = seasonSelect.value;
                const federationId = federationSelect.value;

                searchInput.value = '';
                hiddenInput.value = '';
                competitionSelect.style.display = 'none';
                searchInput.placeholder = 'Laddar serier...';

                try {
                    const response = await fetch(`/Home/GetCompetitions?seasonId=${seasonId}&federationId=${federationId}`);
                    const data = await response.json();

                    competitionSelect.innerHTML = '';
                    allOptions = data.map(c => ({ value: c.competitionID.toString(), text: c.name }));

                    allOptions.forEach(o => {
                        const opt = document.createElement('option');
                        opt.value = o.value;
                        opt.text = o.text;
                        competitionSelect.appendChild(opt);
                    });

                    searchInput.placeholder = `Sök bland ${allOptions.length} serier...`;
                } catch (e) {
                    searchInput.placeholder = 'Kunde inte ladda serier';
                }
            }

            // Show list on focus
            searchInput.addEventListener('focus', function () {
                filterAndShow('');
            });

            // Filter on input
            searchInput.addEventListener('input', function () {
                filterAndShow(this.value);
            });

            // Handle selection
            competitionSelect.addEventListener('change', selectCompetition);
            competitionSelect.addEventListener('dblclick', selectCompetition);

            function selectCompetition() {
                const selected = competitionSelect.options[competitionSelect.selectedIndex];
                if (selected) {
                    hiddenInput.value = selected.value;
                    searchInput.value = selected.text;
                    competitionSelect.style.display = 'none';
                }
            }

            // Hide on click outside
            document.addEventListener('click', function (e) {
                if (!searchInput.contains(e.target) && !competitionSelect.contains(e.target)) {
                    competitionSelect.style.display = 'none';
                }
            });

            function filterAndShow(query) {
                const lower = query.toLowerCase();
                competitionSelect.innerHTML = '';

                const filtered = allOptions.filter(o =>
                    o.text.toLowerCase().includes(lower)
                );

                filtered.forEach(o => {
                    const opt = document.createElement('option');
                    opt.value = o.value;
                    opt.text = o.text;
                    competitionSelect.appendChild(opt);
                });

                competitionSelect.style.display = filtered.length > 0 ? 'block' : 'none';
            }

            // Pre-fill if we have a selection
            if (hiddenInput.value) {
                const match = allOptions.find(o => o.value === hiddenInput.value);
                if (match) searchInput.value = match.text;
            }

            // Set initial placeholder
            searchInput.placeholder = `Sök bland ${allOptions.length} serier...`;
        });
    </script>
}
